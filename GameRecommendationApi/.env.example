# ==============================================================================
# 1. PODEŠAVANJA ZA NEO4J KONTEJNER (Sama baza podataka)
# ==============================================================================
# Format mora biti "username/password". Ovo Docker koristi da prvi put kreira bazu.
NEO4J_AUTH=neo4j/Sifra123

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=Sifra123

# ==============================================================================
# 2. PODEŠAVANJA ZA ASP.NET CORE (Kako se API kači na bazu)
# ==============================================================================
# NAPOMENA: URI mora biti ime kontejnera baze ("neo4j"), a ne "localhost"!
# Duple donje crte (__) se koriste za overridovanje appsettings.json fajla.
Neo4j__Uri=bolt://neo4j:7687
Neo4j__Username=neo4j
Neo4j__Password=TvojaTajnaSifra123


# ==============================================================================
# 3. AUTORIZACIJA (Zaštita API endpointa)
# ==============================================================================
# Tajni ključ koji klijent mora da pošalje u Header-u da bi koristio API.
AUTHORIZATION_APIKEY=Neki_Tajni_Kljuct
Authorization__ApiKey=Neki_Tajni_Kljuc


# ==============================================================================
# 4. LOGOVANJE (Koliko detaljno terminal ispisuje greške)
# ==============================================================================
LOGGING_LOGLEVEL_DEFAULT=Information
LOGGING_LOGLEVEL_ASPNETCORE=Warning